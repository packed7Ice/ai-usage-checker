{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ai-usage-checker",
  "version": "0.1.0",
  "identifier": "com.zutuu.ai-usage-checker",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Usage Checker",
        "width": 960,
        "height": 640,
        "minWidth": 960,
        "minHeight": 640,
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.ico",
      "iconAsTemplate": false,
      "menuOnLeftClick": false,
      "title": "AI Usage Checker",
      "tooltip": "AI CLI Usage Tracker"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
